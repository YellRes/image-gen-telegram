# Telegram Bot Configuration
# Get your bot token from @BotFather on Telegram
TG_BOT_TOKEN=xxx

# Minimax API Configuration
# Get your API key from https://platform.minimax.chat/
MINIMAX_API_KEY=xxx
MINIMAX_GROUP_ID=your-minimax-group-id-here

# Douyin Auto Publish (Playwright)
# 1) set ENABLE_DOUYIN_IMAGE_PUBLISH=true to enable auto publish
# 2) run login once to generate cookie file in social-auto-upload/cookies/douyin_uploader/account.json
ENABLE_DOUYIN_IMAGE_PUBLISH=false
DOUYIN_ACCOUNT_FILE=
DOUYIN_LOGIN_INTERACTIVE=false
DOUYIN_PUBLISH_TAGS=AI绘画,自动发布
